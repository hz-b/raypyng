# python virtual environment
.venv/
.token
Export_Parts
# python specific
__pycache__/

# local-only files, including data which should NOT end in the repo
local/

# Ignoring simulation outputs in manual tests
tests/manual_tests/**/RAYPy_Simulation_*

# Ignore distribution on pip
dist
build/
*.egg-info/
src/raypyng_test.egg-info
src/raypyng.egg-info/dependency_links.txt
src/raypyng.egg-info/PKG-INFO
src/raypyng.egg-info/requires.txt
src/raypyng.egg-info/SOURCES.txt
src/raypyng.egg-info/top_level.txt

# Sphinx build output and docs venvs
docs/_build/
docs/_html/
docs/images/
docs/**/__pycache__/
docs/**/*.bak
venv_docs/

#ignore vscode stuff
.vscode/configurationCache.log
.vscode/dryrun.log
.vscode/targets.log

# ignore output of examples/tests
examples/rml/new_dipole_beamline.rml
examples/test_exportDetectorAtFocus-RawRaysOutgoing.csv
examples/test_exportDipole-RawRaysOutgoing.csv

# generated outputs from the per-example folders (eval plots, demo artefacts)
examples/*/*.png
examples/*/eval_*.png
examples/**/inspect_output/
examples/*/RAYPy_Simulation_*/round_*/
examples/rml_demo/new_dipole_beamline.rml
examples/runner_demo/test_export*.csv
